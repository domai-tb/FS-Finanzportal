# ============================================================
# FS-Finanzportal – Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ----- WordPress / MariaDB -----
WORDPRESS_DB_HOST=mariadb
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress_secret

MYSQL_ROOT_PASSWORD=mysql_root_secret
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress_secret

# WordPress site settings (used by wp-install.sh)
WP_URL=http://localhost:8080
WP_TITLE=FS Finanzportal
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin_secret
WP_ADMIN_EMAIL=admin@example.com

# ----- Keycloak / PostgreSQL -----
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak_secret
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin_secret
KC_HOSTNAME=localhost

POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=keycloak_secret

# ----- Port mapping (host:container) -----
WP_PORT=8080
KC_PORT=8180
